{
    "interface_version": 2,
    "name": "Maa_Kes",
    "description": "PC端请管理员方式启动",
    "contact": "QQ群: 437587416",
    "license": "MIT",
    "welcome": "维若妮卡已就位！",
    "icon": "./resource/image/logo.png",
