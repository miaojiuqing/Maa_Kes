    "version": "1.0.0",
    "mirrorchyan_rid": "MaaKes",
    "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "description": "一定要用管理员身份运行!!!不然连不上窗口",
            "win32": {
                "class_regex": "GLFW30",
                "window_regex": "卡厄思梦境|Chaos Zero Nightmare",
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "简中",
            "path": [
                "./resource"
            ]
        }
        // {
        //     "name": "B 服",
